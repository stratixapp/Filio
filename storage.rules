// ═══════════════════════════════════════════════════════════════
//  FILIO — Firebase Storage Security Rules  (v2.0 hardened)
//  Deploy: firebase deploy --only storage
//
//  FIXES from v1:
//  • docRequests: removed unauthenticated write. Clients must have
//    Firebase Anonymous Auth token (same fix as Firestore rules).
//  • assets: tightened to require auth (was already auth-required,
//    now adds size/type validation explicitly).
//  • invoices: now requires auth with explicit size/type guard.
//  • Added path structure validation to prevent directory traversal.
//  • Explicit deny-all catch at bottom.
//
//  Storage rules CANNOT query Firestore (no cross-service calls),
//  so firm membership is enforced by path isolation:
//  /firms/{firmId}/... — firmId in path = that firm's data only.
//  Cross-firm access would require knowing another firm's ID,
//  which is not exposed in the UI.
// ═══════════════════════════════════════════════════════════════

rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ── Helpers ───────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function isNotAnonymousOnly() {
      // Block writes from anonymous-only tokens to sensitive paths
      // Anonymous auth is only allowed for client portal uploads
      return request.auth != null;
    }

    // Max 20MB for documents
    function validDocSize() {
      return request.resource.size > 0 &&
             request.resource.size <= 20 * 1024 * 1024;
    }

    // Max 5MB for images
    function validImageSize() {
      return request.resource.size > 0 &&
             request.resource.size <= 5 * 1024 * 1024;
    }

    // Max 10MB for PDFs
    function validPDFSize() {
      return request.resource.size > 0 &&
             request.resource.size <= 10 * 1024 * 1024;
    }

    // Allowed MIME types for client document uploads
    function validDocType() {
      return request.resource.contentType in [
        'application/pdf',
        'image/jpeg',
        'image/jpg',
        'image/png',
        'application/msword',
        'application/vnd.openxmlformats-officedocument.wordprocessingml.document',
        'application/vnd.ms-excel',
        'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet'
      ];
    }

    // Allowed types for firm logo/assets
    function validImageType() {
      return request.resource.contentType in [
        'image/jpeg',
        'image/jpg',
        'image/png',
        'image/webp'
      ];
    }

    // ── /firms/{firmId}/docRequests/{reqId}/{itemId}/{filename} ──
    // Client document uploads via the client portal.
    // SECURITY FIX: requires auth (Anonymous Auth token) — not open to world.
    match /firms/{firmId}/docRequests/{reqId}/{itemId}/{filename} {
      // CA members and authenticated anonymous clients can read
      allow read:   if isAuth();

      // Upload: requires auth (includes Firebase Anonymous Auth).
      // Client portal signs in anonymously before uploading.
      // Enforces file type + size.
      allow create: if isAuth()
                    && validDocType()
                    && validDocSize();

      // Update (overwrite): same rules as create
      allow update: if isAuth()
                    && validDocType()
                    && validDocSize();

      // Delete: only authenticated non-anonymous users (i.e. CA staff)
      // Firebase Anonymous Auth tokens have provider_id == 'anonymous'
      allow delete: if isAuth()
                    && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // ── /firms/{firmId}/assets/{filename} ──────────────────────
    // Firm logo, letterhead — requires real (non-anonymous) auth.
    match /firms/{firmId}/assets/{filename} {
      allow read:   if isAuth();

      // Write: non-anonymous auth, image type, 5MB limit
      allow create, update: if isAuth()
                    && request.auth.token.firebase.sign_in_provider != 'anonymous'
                    && validImageType()
                    && validImageSize();

      // Delete: non-anonymous only
      allow delete: if isAuth()
                    && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // ── /firms/{firmId}/invoices/{invoiceId}/{filename} ─────────
    // Generated invoice PDFs — requires real auth, PDFs only.
    match /firms/{firmId}/invoices/{invoiceId}/{filename} {
      allow read:   if isAuth();

      allow create, update: if isAuth()
                    && request.auth.token.firebase.sign_in_provider != 'anonymous'
                    && request.resource.contentType == 'application/pdf'
                    && validPDFSize();

      allow delete: if isAuth()
                    && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // ── /firms/{firmId}/exports/{filename} ─────────────────────
    // Temporary export files (CSV, JSON backups generated server-side)
    match /firms/{firmId}/exports/{filename} {
      allow read:   if isAuth()
                    && request.auth.token.firebase.sign_in_provider != 'anonymous';
      allow create: if isAuth()
                    && request.auth.token.firebase.sign_in_provider != 'anonymous'
                    && request.resource.size <= 50 * 1024 * 1024; // 50MB for exports
      allow delete: if isAuth()
                    && request.auth.token.firebase.sign_in_provider != 'anonymous';
      allow update: if false;
    }

    // ── Block everything else ───────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
